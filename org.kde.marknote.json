{
    "id": "org.kde.marknote",
    "runtime": "org.kde.Platform",
    "runtime-version": "6.10",
    "sdk": "org.kde.Sdk",
    "command": "marknote",
    "finish-args": [
        "--device=dri",
        "--filesystem=xdg-documents",
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland"
    ],
    "cleanup": [
        "/include",
        "/lib/cmake",
        "/share/qlogging-categories6"
    ],
    "modules": [
        {
            "name": "kmime",
            "config-opts": [
                "-DBUILD_TESTING=OFF",
                "-DCMAKE_BUILD_TYPE=Release"
            ],
            "buildsystem": "cmake-ninja",
            "builddir": true,
            "sources": [
                {
                    "type": "archive",
                    "url": "https://download.kde.org/stable/release-service/25.12.3/src/kmime-25.12.3.tar.xz",
                    "sha256": "fce3c603cac3fec9a3f0e101c49785c32ace07b8f60b52739b638d329f43826d",
                    "x-checker-data": {
                        "type": "anitya",
                        "project-id": 8763,
                        "stable-only": true,
                        "url-template": "https://download.kde.org/stable/release-service/$version/src/kmime-$version.tar.xz"
                    }
                }
            ]
        },
        {
            "name": "marknote",
            "buildsystem": "cmake-ninja",
            "builddir": true,
            "sources": [
                {
                    "type": "archive",
                    "url": "https://download.kde.org/stable/marknote/marknote-1.5.0.tar.xz",
                    "sha256": "6c1fa7159da0db50296f231716bbe267b6d7416864ca7da4551a50963ab8abb5",
                    "x-checker-data": {
                        "type": "anitya",
                        "project-id": 371890,
                        "stable-only": true,
                        "url-template": "https://download.kde.org/stable/marknote/marknote-$version.tar.xz"
                    }
                }
            ]
        }
    ]
}
